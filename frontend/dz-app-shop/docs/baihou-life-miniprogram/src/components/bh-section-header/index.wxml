<view class="bh-section-header">
  <view>
    <view class="bh-section-header__title">{{title}}</view>
    <view wx:if="{{subtitle}}" class="bh-section-header__subtitle">{{subtitle}}</view>
  </view>
  <view wx:if="{{actionText}}" class="bh-section-header__action" bindtap="handleAction">{{actionText}}</view>
</view>
