.bh-shell__hero {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 32rpx;
  background:
    radial-gradient(circle at top left, rgba(125, 138, 99, 0.18), transparent 34%),
    linear-gradient(180deg, rgba(255, 252, 248, 0.96), rgba(247, 244, 239, 0.88));
}

.bh-shell__hero--compact {
  padding-bottom: 18rpx;
}

.bh-shell__toolbar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bh-shell__back,
.bh-shell__brand {
  font-size: 24rpx;
  color: #6c655e;
}

.bh-shell__back {
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.bh-shell__headline {
  padding-top: 12rpx;
}

.bh-shell__title {
  display: block;
  font-size: 50rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #2f2a26;
}

.bh-shell__subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6c655e;
}

.bh-shell__body {
  padding-top: 18rpx;
}
