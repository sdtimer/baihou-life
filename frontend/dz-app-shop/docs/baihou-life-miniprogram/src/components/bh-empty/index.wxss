.bh-empty {
  padding: 40rpx 32rpx;
  text-align: center;
}

.bh-empty__icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 18rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.18), rgba(125, 138, 99, 0.16));
  color: #6f5a45;
  font-size: 42rpx;
  font-weight: 600;
}

.bh-empty__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2a26;
}

.bh-empty__subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8c847c;
}
