<bh-shell title="登录后继续你的选品进程" subtitle="游客、客户、设计师会自动切换不同价格和权限能力。">
  <view class="auth-card bh-card">
    <view class="auth-card__title">微信一键登录</view>
    <view class="auth-card__subtitle">按一期方案，角色与价格展示完全由登录态统一控制。</view>
    <view class="auth-card__list">
      <view wx:for="{{benefits}}" wx:key="*this" class="auth-card__item">
        <text class="auth-card__dot"></text>
        <text>{{item}}</text>
      </view>
    </view>
    <button class="bh-button-primary auth-card__button" loading="{{loading}}" bindtap="login">授权登录</button>
  </view>
</bh-shell>
