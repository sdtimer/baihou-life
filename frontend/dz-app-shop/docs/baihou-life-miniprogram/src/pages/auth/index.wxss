.auth-card {
  padding: 36rpx 30rpx;
}

.auth-card__title {
  font-size: 36rpx;
  font-weight: 600;
}

.auth-card__subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6c655e;
}

.auth-card__list {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
}

.auth-card__item {
  display: flex;
  gap: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #2f2a26;
}

.auth-card__dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #7d8a63;
}

.auth-card__button {
  margin-top: 30rpx;
}
