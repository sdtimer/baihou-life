<bh-shell title="我的预约" subtitle="状态显示需和后端状态机保持一致。">
  <button class="bh-button-primary appointment-create" bindtap="goCreate">新建预约</button>
  <view wx:if="{{rows.length}}" class="appointment-list">
    <view wx:for="{{rows}}" wx:key="appointment_id" class="appointment-item bh-card">
      <view class="appointment-item__top">
        <view>
          <view class="appointment-item__no">{{item.appointment_no}}</view>
          <view class="appointment-item__meta">{{item.region_name}} · {{item.preferred_date}}</view>
        </view>
        <bh-status-chip status="{{item.status}}" text="{{item.status_text}}" />
      </view>
      <view class="appointment-item__service">服务类型：{{item.service_type}}</view>
    </view>
  </view>
  <bh-empty wx:else title="你还没有预约记录" subtitle="预约量尺、安装或配送后，会在这里看到状态更新。" />
  <bh-dock-nav current="appointment" />
</bh-shell>
