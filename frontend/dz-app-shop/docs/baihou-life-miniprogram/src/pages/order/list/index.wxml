<bh-shell title="我的订单" subtitle="按状态理解当前进度，而不是被复杂流程打断。">
  <view wx:if="{{rows.length}}" class="order-list">
    <view wx:for="{{rows}}" wx:key="order_id" class="order-item bh-card" data-id="{{item.order_id}}" bindtap="openDetail">
      <view class="order-item__top">
        <view>
          <view class="order-item__no">{{item.order_no}}</view>
          <view class="order-item__meta">{{item.created_at}} · {{item.region_name}}</view>
        </view>
        <bh-status-chip status="{{item.status}}" text="{{item.status_text}}" />
      </view>
      <view class="order-item__name">{{item.product_name}}</view>
      <view class="order-item__amount">¥{{item.pay_amount}}</view>
    </view>
  </view>
  <bh-empty wx:else title="暂无订单" subtitle="完成下单后，这里会展示支付、发货和完成状态。" />
  <bh-dock-nav current="order" />
</bh-shell>
