.form-card {
  display: grid;
  gap: 18rpx;
  padding: 30rpx;
}

.form-card__context {
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f3eee8;
  color: #6f5a45;
  font-size: 24rpx;
}

.form-card__input,
.form-card__textarea {
  width: 100%;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f7f4ef;
  font-size: 28rpx;
}

.form-card__textarea {
  min-height: 220rpx;
}
