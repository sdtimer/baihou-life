.detail-swiper {
  overflow: hidden;
}

.detail-swiper,
.detail-swiper__image {
  width: 100%;
  height: 680rpx;
}

.detail-summary,
.detail-specs {
  padding: 28rpx;
  margin-top: 20rpx;
}

.detail-summary__brand {
  font-size: 24rpx;
  color: #8c847c;
}

.detail-summary__name {
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
}

.detail-summary__desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6c655e;
}

.detail-summary__price {
  margin-top: 24rpx;
}

.detail-summary__hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #9b938b;
}

.detail-specs__title {
  font-size: 32rpx;
  font-weight: 600;
}

.detail-specs__row {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(221, 213, 204, 0.72);
}

.detail-specs__label {
  color: #8c847c;
}

.detail-specs__value {
  flex: 1;
  text-align: right;
  color: #2f2a26;
}

.detail-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-actions .bh-button-primary {
  grid-column: span 2;
}
