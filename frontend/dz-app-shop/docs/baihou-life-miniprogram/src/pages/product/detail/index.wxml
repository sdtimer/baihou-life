<bh-shell title="产品详情" subtitle="大图、规格、价格层级和动作区统一按设计系统组织。">
  <bh-empty wx:if="{{!product}}" title="商品暂不可访问" subtitle="该商品可能已下架，或当前区域暂不支持。" />
  <block wx:else>
    <swiper class="detail-swiper bh-card" indicator-dots autoplay circular>
      <swiper-item wx:for="{{product.gallery}}" wx:key="*this">
        <image class="detail-swiper__image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>

    <view class="detail-summary bh-card">
      <view class="detail-summary__brand">{{product.brand}} · {{product.category_name}}</view>
      <view class="detail-summary__name">{{product.name}}</view>
      <view class="detail-summary__desc">{{product.description}}</view>
      <view class="bh-price detail-summary__price">
        <text wx:if="{{isDesigner}}" class="bh-price__secondary">¥{{product.guide_price}}</text>
        <text class="bh-price__main">¥{{isDesigner ? product.designer_price : product.guide_price}}</text>
        <text class="bh-meta">{{product.price_unit}}</text>
      </view>
      <view wx:if="{{!isDesigner}}" class="detail-summary__hint">设计师登录后可查看专属折扣价与素材下载入口。</view>
    </view>

    <view class="detail-specs bh-card">
      <view class="detail-specs__title">规格参数</view>
      <view wx:for="{{product.specs}}" wx:key="label" class="detail-specs__row">
        <text class="detail-specs__label">{{item.label}}</text>
        <text class="detail-specs__value">{{item.value}}</text>
      </view>
    </view>

    <view class="detail-actions">
      <button class="bh-button-secondary" bindtap="goLead">留资咨询</button>
      <button class="bh-button-secondary" bindtap="goAssets" wx:if="{{isDesigner}}">设计师素材</button>
      <button class="bh-button-primary" bindtap="goOrder">立即下单</button>
    </view>
  </block>
</bh-shell>
