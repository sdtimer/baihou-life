.bh-picker {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  background: var(--color-surface-base);
  transition: border-color 0.2s ease;
}

.bh-picker:active {
  border-color: var(--color-brand-primary);
}

.bh-picker--disabled {
  background: var(--color-disabled-bg);
  opacity: 0.6;
}

.bh-picker__label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.bh-picker__content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.bh-picker__value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bh-picker__placeholder {
  color: var(--color-text-tertiary);
}

.bh-picker__arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--color-text-tertiary);
  border-bottom: 3rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.bh-picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999 !important;
  visibility: hidden;
  transition: visibility 0.3s ease;
}

.bh-picker-popup--visible {
  visibility: visible;
}

.bh-picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.bh-picker-popup--visible .bh-picker-mask {
  opacity: 1;
}

.bh-picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.bh-picker-popup--visible .bh-picker-panel {
  transform: translateY(0);
}

.bh-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
  flex-shrink: 0;
}

.bh-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.bh-picker-cancel {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 16rpx;
}

.bh-picker-confirm {
  font-size: 28rpx;
  color: var(--color-brand-primary);
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.bh-picker-body {
  flex: 1;
  overflow: hidden;
}

.bh-picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
  transition: background 0.2s ease;
}

.bh-picker-option:last-child {
  border-bottom: none;
}

.bh-picker-option:active {
  background: var(--color-bg-base);
}

.bh-picker-option--active {
  background: var(--color-brand-primary-soft);
}

.bh-picker-option__text {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.bh-picker-option--active .bh-picker-option__text {
  color: var(--color-brand-primary);
  font-weight: 500;
}

.bh-picker-option__check {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.bh-picker-option__check::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 12rpx;
  height: 22rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}