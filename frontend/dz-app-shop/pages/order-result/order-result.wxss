.page {
  min-height: 100vh;
  background: var(--color-bg-base);
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  background: var(--color-surface-base);
}

.result-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 32rpx;
  position: relative;
}

.result-icon.success {
  background: var(--color-success);
}

.result-icon.fail {
  background: var(--color-error);
}

.result-icon.success::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 36rpx;
  height: 18rpx;
  border-left: 6rpx solid #fff;
  border-bottom: 6rpx solid #fff;
  transform: translate(-50%, -60%) rotate(-45deg);
}

.result-icon.fail::before,
.result-icon.fail::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 48rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 3rpx;
}

.result-icon.fail::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.result-icon.fail::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.result-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.result-order {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 32rpx;
}

.result-price {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 48rpx;
  background: var(--color-brand-primary-soft);
  border-radius: var(--radius-lg);
}

.price-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.price-value {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.result-tips {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.section {
  padding: 24rpx 32rpx;
}

.tips-card {
  padding: 32rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg);
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-surface-base);
  border-top: 1rpx solid var(--color-border-default);
}

.bottom-buttons {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.bottom-buttons .btn {
  flex: 1;
  height: 88rpx;
}