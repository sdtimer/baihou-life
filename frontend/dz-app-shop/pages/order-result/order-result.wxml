<view class="page">
  <view class="result-card">
    <view class="result-icon {{status === 'success' ? 'success' : 'fail'}}"></view>
    <view class="result-title">{{status === 'success' ? '支付成功' : '支付失败'}}</view>
    <view class="result-order">订单号：{{orderId}}</view>
    
    <view class="result-price" wx:if="{{status === 'success'}}">
      <text class="price-label">支付金额</text>
      <text class="price-value">¥{{totalPrice}}</text>
    </view>
    
    <view class="result-tips" wx:if="{{status === 'fail'}}">
      支付遇到问题，请重新尝试
    </view>
  </view>

  <view class="section">
    <view class="tips-card">
      <view class="tips-title">温馨提示</view>
      <view class="tips-list">
        <view class="tips-item">1. 您可以在"订单"页面查看订单状态</view>
        <view class="tips-item">2. 如有问题请联系客服：400-888-8888</view>
        <view class="tips-item">3. 商品发货后会有短信通知</view>
      </view>
    </view>
  </view>

  <view class="bottom-bar safe-area-bottom">
    <view class="bottom-buttons">
      <view class="btn btn-secondary" bindtap="goHome">返回首页</view>
      <view class="btn btn-primary" bindtap="goOrder">查看订单</view>
    </view>
  </view>
</view>