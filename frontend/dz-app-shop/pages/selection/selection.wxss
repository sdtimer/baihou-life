.page {
  min-height: 100vh;
  background: var(--color-bg-base);
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-surface-base);
  border-bottom: 1rpx solid var(--color-border-default);
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.area-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.area-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.area-arrow {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

.area-placeholder {
  width: 120rpx;
}

.area-picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  transition: visibility 0.3s ease;
}

.area-picker-popup.show {
  visibility: visible;
}

.area-picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.area-picker-popup.show .area-picker-mask {
  opacity: 1;
}

.area-picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.area-picker-popup.show .area-picker-panel {
  transform: translateY(0);
}

.area-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
}

.area-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.area-picker-cancel {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 16rpx;
}

.area-picker-confirm {
  font-size: 28rpx;
  color: var(--color-brand-primary);
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.area-picker-body {
  flex: 1;
  overflow: hidden;
}

.area-picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
}

.area-picker-option:last-child {
  border-bottom: none;
}

.area-picker-option.active {
  background: var(--color-brand-primary-soft);
}

.area-picker-option__text {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.area-picker-option.active .area-picker-option__text {
  color: var(--color-brand-primary);
  font-weight: 500;
}

.area-picker-option__check {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.area-picker-option__check::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 12rpx;
  height: 22rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.nav-tabs {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.nav-tab {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  position: relative;
  padding: 16rpx 0;
  transition: all 0.2s ease;
}

.nav-tab.active {
  color: var(--color-brand-primary);
  font-weight: 600;
}

.nav-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--color-brand-primary);
  border-radius: 3rpx;
}

.sub-tabs-wrap {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  background: var(--color-surface-base);
  border-bottom: 1rpx solid var(--color-border-default);
}

.sub-tabs {
  white-space: nowrap;
  padding: 16rpx 24rpx;
}

.sub-tab {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-surface-muted);
  border-radius: var(--radius-pill);
  transition: all 0.2s ease;
}

.sub-tab:last-child {
  margin-right: 0;
}

.sub-tab.active {
  color: #FFFFFF;
  background: var(--color-brand-primary);
}

.product-list {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-base);
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 24rpx;
}

.product-card {
  background: var(--color-surface-base);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image {
  width: 100%;
  height: 340rpx;
  background: var(--color-surface-muted);
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
  min-height: 78rpx;
}

.product-spec {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 12rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.price-unit {
  font-size: 22rpx;
  color: var(--color-brand-primary);
  font-weight: 500;
}

.price-value {
  font-size: 34rpx;
  color: var(--color-brand-primary);
  font-weight: 600;
  margin-left: 2rpx;
}

.price-original {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  text-decoration: line-through;
}

.product-tags {
  display: flex;
  gap: 8rpx;
}

.product-tags .tag {
  height: 40rpx;
  padding: 0 12rpx;
  font-size: 20rpx;
}

.empty {
  padding: 120rpx 32rpx;
  text-align: center;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  background: var(--color-surface-muted);
  border-radius: 50%;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.load-more {
  padding: 32rpx;
  text-align: center;
}

.load-more-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}