<view class="page">
  <view class="header" style="padding-top: {{navBarHeight}}px;">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="header-title">预约服务</view>
      <view class="header-desc">专业设计师一对一咨询，为您打造理想空间</view>
    </view>
  </view>

  <view class="form-card">
    <view class="form-item">
      <view class="form-label"><text class="required">*</text>姓名</view>
      <input class="input" placeholder="请输入您的姓名" placeholder-class="input-placeholder" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>

    <view class="form-item">
      <view class="form-label"><text class="required">*</text>手机号</view>
      <input class="input" type="number" placeholder="请输入您的手机号" placeholder-class="input-placeholder" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>

    <view class="form-item">
      <view class="form-label"><text class="required">*</text>所在区域</view>
      <view class="picker-trigger" bindtap="openRegionPicker">
        <view class="picker-value {{form.region ? '' : 'picker-placeholder'}}">
          {{regionLabel || '请选择区域'}}
        </view>
        <view class="picker-arrow"></view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">房屋面积</view>
      <view class="input-suffix">
        <input class="input" type="number" placeholder="请输入房屋面积" placeholder-class="input-placeholder" value="{{form.area}}" bindinput="onInput" data-field="area" />
        <view class="suffix-text">m²</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">装修阶段</view>
      <view class="picker-trigger" bindtap="openStagePicker">
        <view class="picker-value {{form.stage ? '' : 'picker-placeholder'}}">
          {{stageLabel || '请选择装修阶段'}}
        </view>
        <view class="picker-arrow"></view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">期望风格</view>
      <view class="tag-group">
        <view 
          class="tag-select {{form.style === item.value ? 'active' : ''}}" 
          wx:for="{{styleOptions}}" 
          wx:key="value"
          bindtap="onStyleSelect"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">备注说明</view>
      <textarea class="textarea" placeholder="请描述您的需求或问题，设计师会为您提供专业建议" placeholder-class="input-placeholder" value="{{form.remark}}" bindinput="onInput" data-field="remark" />
    </view>
  </view>

  <view class="submit-bar safe-area-bottom">
    <view class="agreement">
      <view class="checkbox {{agreed ? 'active' : ''}}" bindtap="onAgree"></view>
      <view class="agreement-text">我已阅读并同意<text class="link">《服务协议》</text>和<text class="link">《隐私政策》</text></view>
    </view>
    <view class="btn btn-primary" bindtap="onSubmit">提交预约</view>
  </view>

  <view class="picker-popup {{pickerVisible ? 'picker-popup--visible' : ''}}" catchtouchmove="preventMove">
    <view class="picker-mask" bindtap="closePicker"></view>
    <view class="picker-panel">
      <view class="picker-header">
        <view class="picker-cancel" bindtap="closePicker">取消</view>
        <view class="picker-title">{{pickerTitle}}</view>
        <view class="picker-confirm" bindtap="confirmPicker">确定</view>
      </view>
      <scroll-view scroll-y class="picker-body">
        <view 
          wx:for="{{pickerOptions}}" 
          wx:key="value" 
          class="picker-option {{tempPickerValue === item.value ? 'picker-option--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="selectPickerOption"
        >
          <view class="picker-option__text">{{item.label}}</view>
          <view class="picker-option__check" wx:if="{{tempPickerValue === item.value}}"></view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>