.page {
  min-height: 100vh;
  background: var(--color-bg-base);
  padding-bottom: 240rpx;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: transparent;
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.header {
  position: relative;
  padding: 56rpx 32rpx 120rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-brand-primary) 0%, var(--color-brand-accent) 100%);
}

.header-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle at 30% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

.form-card {
  margin: -48rpx 24rpx 24rpx;
  padding: 32rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-2);
  position: relative;
  z-index: 1;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.required {
  color: var(--color-error);
  margin-right: 4rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-surface-base);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.input:focus {
  border-color: var(--color-brand-primary);
}

.input-placeholder {
  color: var(--color-text-tertiary);
}

.input-suffix {
  position: relative;
}

.input-suffix .input {
  padding-right: 80rpx;
}

.suffix-text {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  background: var(--color-surface-base);
  transition: border-color 0.2s ease;
}

.picker:active {
  border-color: var(--color-brand-primary);
}

.picker-value {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--color-text-tertiary);
  border-bottom: 3rpx solid var(--color-text-tertiary);
  transform: rotate(-45deg);
}

.radio-group {
  display: flex;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-surface-base);
  transition: all 0.2s ease;
}

.radio-item.active {
  border-color: var(--color-brand-primary);
  color: var(--color-brand-primary);
  background: var(--color-brand-primary-soft);
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-select {
  padding: 18rpx 32rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-surface-base);
  transition: all 0.2s ease;
}

.tag-select.active {
  border-color: var(--color-brand-primary);
  color: var(--color-brand-primary);
  background: var(--color-brand-primary-soft);
}

.textarea {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-surface-base);
  box-sizing: border-box;
  line-height: 1.5;
  transition: border-color 0.2s ease;
}

.textarea:focus {
  border-color: var(--color-brand-primary);
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: var(--color-surface-base);
  border-top: 1rpx solid var(--color-border-default);
  z-index: 100;
}

.agreement {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--color-border-default);
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  position: relative;
  transition: all 0.2s ease;
}

.checkbox.active {
  background: var(--color-brand-primary);
  border-color: var(--color-brand-primary);
}

.checkbox.active::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 6rpx;
  width: 10rpx;
  height: 18rpx;
  border: 3rpx solid #FFFFFF;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.agreement-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.link {
  color: var(--color-brand-primary);
}

.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  background: var(--color-surface-base);
  transition: border-color 0.2s ease;
}

.picker-trigger:active {
  border-color: var(--color-brand-primary);
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-placeholder {
  color: var(--color-text-tertiary);
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--color-text-tertiary);
  border-bottom: 3rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  visibility: hidden;
  transition: visibility 0.3s ease;
}

.picker-popup--visible {
  visibility: visible;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.picker-popup--visible .picker-mask {
  opacity: 1;
}

.picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.picker-popup--visible .picker-panel {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
  flex-shrink: 0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-cancel {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 16rpx;
}

.picker-confirm {
  font-size: 28rpx;
  color: var(--color-brand-primary);
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.picker-body {
  flex: 1;
  overflow: hidden;
}

.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
  transition: background 0.2s ease;
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background: var(--color-bg-base);
}

.picker-option--active {
  background: var(--color-brand-primary-soft);
}

.picker-option__text {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.picker-option--active .picker-option__text {
  color: var(--color-brand-primary);
  font-weight: 500;
}

.picker-option__check {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.picker-option__check::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 12rpx;
  height: 22rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}