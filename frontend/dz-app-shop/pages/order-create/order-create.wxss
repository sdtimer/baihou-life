.page {
  min-height: 100vh;
  background: var(--color-bg-base);
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  background: var(--color-surface-base);
  border-bottom: 1rpx solid var(--color-border-default);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -16rpx;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid var(--color-text-primary);
  border-bottom: 4rpx solid var(--color-text-primary);
  transform: rotate(45deg);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-right: 64rpx;
}

.content {
  padding-top: 88rpx;
}

.section {
  padding: 32rpx;
  background: var(--color-surface-base);
  margin-bottom: 24rpx;
}

.address-card {
  position: relative;
  padding-right: 40rpx;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.address-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  background: var(--color-brand-primary);
  border-radius: 50%;
  position: relative;
}

.address-icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -60%);
  width: 12rpx;
  height: 12rpx;
  background: #fff;
  border-radius: 50%;
}

.address-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -20%);
  width: 18rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 0 0 10rpx 10rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-right: 24rpx;
}

.address-phone {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.address-detail {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  padding-left: 52rpx;
}

.address-arrow {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid var(--color-text-tertiary);
  border-top: 4rpx solid var(--color-text-tertiary);
  transform: translateY(-50%) rotate(45deg);
}

.address-empty {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.address-add-icon {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx dashed var(--color-border-strong);
  border-radius: 50%;
  margin-right: 24rpx;
  position: relative;
}

.address-add-icon::before,
.address-add-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  background: var(--color-text-tertiary);
}

.address-add-icon::before {
  width: 24rpx;
  height: 2rpx;
}

.address-add-icon::after {
  width: 2rpx;
  height: 24rpx;
}

.address-add-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-brand-primary);
}

.goods-card {
  display: flex;
  gap: 24rpx;
}

.goods-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--color-surface-muted);
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-desc {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.goods-spec {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 16rpx;
}

.goods-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.goods-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: var(--color-brand-primary);
  font-weight: 600;
}

.price-value {
  font-size: 36rpx;
  color: var(--color-brand-primary);
  font-weight: 600;
}

.goods-quantity {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.info-label {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.info-value {
  display: flex;
  align-items: center;
  padding-right: 24rpx;
}

.info-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-text.placeholder {
  color: var(--color-text-tertiary);
}

.info-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid var(--color-text-tertiary);
  border-top: 4rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
  margin-left: 16rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.price-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.price-value.discount {
  color: var(--color-error);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-surface-base);
  border-top: 1rpx solid var(--color-border-default);
}

.bottom-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.total-price {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.submit-btn {
  width: 280rpx;
  height: 80rpx;
  font-size: 30rpx;
}

.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.popup-close {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.popup-close::before,
.popup-close::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 32rpx;
  height: 4rpx;
  background: var(--color-text-tertiary);
  border-radius: 2rpx;
}

.popup-close::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.popup-close::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.popup-body {
  padding: 32rpx;
}

.remark-input {
  width: auto;
  height: 240rpx;
  padding: 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-base);
}

.popup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}