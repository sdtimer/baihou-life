.page {
  min-height: 100vh;
  background: var(--color-bg-base);
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: var(--color-surface-base);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 16rpx;
  padding-right: 16rpx;
  z-index: 100;
  border-bottom: 1rpx solid var(--color-border-default);
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid var(--color-text-primary);
  border-bottom: 4rpx solid var(--color-text-primary);
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.nav-placeholder {
  width: 72rpx;
}

.product-info {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--color-brand-primary-soft) 0%, var(--color-brand-accent-soft) 100%);
  border-radius: var(--radius-md);
  border-left: 6rpx solid var(--color-brand-primary);
}

.product-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.form-card {
  margin-top: 24rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
  padding: 32rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-1);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required {
  color: var(--color-error);
  margin-right: 4rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-base);
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.input:focus {
  border-color: var(--color-brand-primary);
  background: var(--color-surface-base);
}

.input-placeholder {
  color: var(--color-text-tertiary);
}

.textarea {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-base);
  box-sizing: border-box;
  line-height: 1.6;
  transition: all 0.2s ease;
}

.textarea:focus {
  border-color: var(--color-brand-primary);
  background: var(--color-surface-base);
}

.tips {
  margin: 32rpx 24rpx 0;
  padding: 24rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--color-border-default);
}

.tips-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.8;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: var(--color-surface-base);
  border-top: 1rpx solid var(--color-border-default);
  z-index: 100;
}