.page {
  min-height: 100vh;
  background: var(--color-bg-base);
  padding-bottom: calc(100rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.user-header {
  position: relative;
  padding-bottom: 100rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-brand-primary) 0%, var(--color-brand-accent) 100%);
}

.header-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
  flex-shrink: 0;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.user-tag .tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
}

.tag-accent {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.header-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.setting-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
}

.setting-icon::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.8);
}

.stats-card {
  display: flex;
  align-items: center;
  margin: -52rpx 24rpx 24rpx;
  padding: 32rpx 20rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-2);
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 8rpx 0;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-border-default);
}

.menu-card {
  margin: 0 24rpx 24rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-1);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border-default);
  transition: background 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--color-bg-base);
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.menu-icon-order {
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 6rpx;
}

.menu-icon-order::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 14rpx;
  height: 4rpx;
  background: var(--color-brand-primary);
  box-shadow: 0 -7rpx 0 var(--color-brand-primary), 0 7rpx 0 var(--color-brand-primary);
}

.menu-icon-appointment {
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 50%;
}

.menu-icon-appointment::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-brand-primary);
}

.menu-icon-lead {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 50%;
  margin: 4rpx;
}

.menu-icon-lead::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 10rpx solid var(--color-brand-primary);
}

.menu-icon-favorite {
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}

.menu-icon-address {
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 6rpx;
}

.menu-icon-address::before {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 8rpx solid var(--color-brand-primary);
}

.menu-icon-service {
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 50%;
}

.menu-icon-service::before {
  content: '?';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.menu-icon-setting {
  border-radius: 50%;
}

.menu-icon-setting::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 50%;
}

.menu-icon-setting::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 6rpx;
  background: var(--color-brand-primary);
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.menu-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  background: var(--color-error);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-pill);
  margin-right: 12rpx;
}

.menu-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid var(--color-text-tertiary);
  border-bottom: 3rpx solid var(--color-text-tertiary);
  transform: rotate(-45deg);
}

.designer-entry {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--color-brand-accent-soft) 0%, var(--color-brand-primary-soft) 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-brand-accent);
}

.designer-entry:active {
  opacity: 0.9;
}

.designer-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-brand-accent);
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.designer-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
}

.designer-icon::after {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-bottom: 8rpx solid #FFFFFF;
}

.designer-content {
  flex: 1;
}

.designer-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-brand-accent);
  margin-bottom: 4rpx;
}

.designer-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.designer-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid var(--color-brand-accent);
  border-bottom: 3rpx solid var(--color-brand-accent);
  transform: rotate(-45deg);
}