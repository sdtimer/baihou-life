.page {
  min-height: 100vh;
  background: var(--color-bg-base);
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-bottom: 16rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-left: 24rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #FFFFFF;
  border-bottom: 4rpx solid #FFFFFF;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.goods-swiper {
  width: 100%;
  height: 750rpx;
}

.goods-swiper__image {
  width: 100%;
  height: 100%;
}

.goods-info {
  padding: 32rpx;
  background: var(--color-surface-base);
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.goods-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.price-value {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.price-original {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  text-decoration: line-through;
}

.goods-name {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.goods-desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.goods-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.section {
  margin-top: 24rpx;
  padding: 32rpx;
  background: var(--color-surface-base);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.spec-list {
  border-top: 1rpx solid var(--color-border-default);
}

.spec-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-default);
}

.spec-label {
  width: 180rpx;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.spec-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.detail-content {
  padding: 24rpx;
  background: var(--color-surface-muted);
  border-radius: var(--radius-md);
}

.detail-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--color-surface-base);
  border-top: 1rpx solid var(--color-border-default);
  z-index: 100;
}

.bottom-buttons {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.bottom-buttons .btn {
  flex: 1;
  height: 80rpx;
}