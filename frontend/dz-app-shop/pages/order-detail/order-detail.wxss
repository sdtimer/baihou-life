.page {
  min-height: 100vh;
  background: var(--color-bg-base);
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--color-surface-base);
  border-bottom: 1rpx solid var(--color-border-default);
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid var(--color-text-primary);
  border-bottom: 4rpx solid var(--color-text-primary);
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.nav-placeholder {
  width: 72rpx;
}

.scroll-view {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.status-card {
  padding: 48rpx 32rpx;
  text-align: center;
}

.status-card.status-pending {
  background: linear-gradient(135deg, #ff9500 0%, #ff6b00 100%);
}

.status-card.status-paid {
  background: linear-gradient(135deg, var(--color-brand-primary) 0%, var(--color-brand-accent) 100%);
}

.status-card.status-shipped {
  background: linear-gradient(135deg, var(--color-brand-primary) 0%, var(--color-brand-accent) 100%);
}

.status-card.status-completed {
  background: linear-gradient(135deg, #34c759 0%, #30b350 100%);
}

.status-card.status-cancelled {
  background: linear-gradient(135deg, #8e8e93 0%, #636366 100%);
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 20rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.section {
  background: var(--color-surface-base);
  margin-bottom: 20rpx;
}

.section-title {
  padding: 24rpx 28rpx 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.address-card {
  padding: 0 28rpx 24rpx;
}

.address-user {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-right: 20rpx;
}

.user-phone {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.address-detail {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.goods-list {
  padding: 0 28rpx 24rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border-default);
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  background: var(--color-surface-muted);
  flex-shrink: 0;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-spec {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.goods-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.goods-quantity {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.info-list {
  padding: 0 28rpx 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.info-copy {
  font-size: 24rpx;
  color: var(--color-brand-primary);
  padding: 8rpx 16rpx;
  border: 1rpx solid var(--color-brand-primary);
  border-radius: var(--radius-sm);
}

.fee-list {
  padding: 0 28rpx 24rpx;
}

.fee-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.fee-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.fee-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.fee-value.discount {
  color: var(--color-error);
}

.fee-item.total {
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-default);
  margin-top: 8rpx;
}

.fee-item.total .fee-label {
  font-weight: 500;
  color: var(--color-text-primary);
}

.fee-item.total .fee-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.footer-placeholder {
  height: 140rpx;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-surface-base);
  border-top: 1rpx solid var(--color-border-default);
  padding: 20rpx 28rpx;
}

.footer-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  padding: 16rpx 24rpx;
}

.btn-text:active {
  color: var(--color-text-primary);
}

.btn-primary {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: var(--color-brand-primary);
  padding: 16rpx 40rpx;
  border-radius: var(--radius-sm);
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-brand-primary);
  background: var(--color-brand-primary-soft);
  padding: 16rpx 40rpx;
  border-radius: var(--radius-sm);
}

.btn-secondary:active {
  opacity: 0.85;
}