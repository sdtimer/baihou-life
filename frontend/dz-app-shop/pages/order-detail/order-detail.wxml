<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-content">
      <view class="nav-back" bindtap="goBack">
        <view class="back-icon"></view>
      </view>
      <view class="nav-title">订单详情</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <scroll-view class="scroll-view" scroll-y style="top: {{navBarHeight}}px;">
    <view class="status-card status-{{order.status}}">
      <view class="status-icon"></view>
      <view class="status-text">{{order.statusText}}</view>
      <view class="status-desc">{{order.statusDesc}}</view>
    </view>

    <view class="section">
      <view class="section-title">收货信息</view>
      <view class="address-card">
        <view class="address-user">
          <text class="user-name">{{order.address.name}}</text>
          <text class="user-phone">{{order.address.phone}}</text>
        </view>
        <view class="address-detail">{{order.address.detail}}</view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">商品信息</view>
      <view class="goods-list">
        <view class="goods-item" wx:for="{{order.goods}}" wx:key="id">
          <image class="goods-image" src="{{item.image}}" mode="aspectFill" />
          <view class="goods-info">
            <view class="goods-name">{{item.name}}</view>
            <view class="goods-spec">{{item.spec}}</view>
            <view class="goods-price-row">
              <view class="goods-price">¥{{item.price}}</view>
              <view class="goods-quantity">x{{item.quantity}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">订单信息</view>
      <view class="info-list">
        <view class="info-item">
          <view class="info-label">订单编号</view>
          <view class="info-value">{{order.orderNo}}</view>
          <view class="info-copy" bindtap="copyOrderNo">复制</view>
        </view>
        <view class="info-item">
          <view class="info-label">下单时间</view>
          <view class="info-value">{{order.createTime}}</view>
        </view>
        <view class="info-item" wx:if="{{order.payTime}}">
          <view class="info-label">付款时间</view>
          <view class="info-value">{{order.payTime}}</view>
        </view>
        <view class="info-item" wx:if="{{order.shipTime}}">
          <view class="info-label">发货时间</view>
          <view class="info-value">{{order.shipTime}}</view>
        </view>
        <view class="info-item" wx:if="{{order.completeTime}}">
          <view class="info-label">完成时间</view>
          <view class="info-value">{{order.completeTime}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">费用明细</view>
      <view class="fee-list">
        <view class="fee-item">
          <view class="fee-label">商品金额</view>
          <view class="fee-value">¥{{order.goodsAmount}}</view>
        </view>
        <view class="fee-item">
          <view class="fee-label">运费</view>
          <view class="fee-value">¥{{order.freight}}</view>
        </view>
        <view class="fee-item" wx:if="{{order.discount > 0}}">
          <view class="fee-label">优惠</view>
          <view class="fee-value discount">-¥{{order.discount}}</view>
        </view>
        <view class="fee-item total">
          <view class="fee-label">实付款</view>
          <view class="fee-value">¥{{order.totalAmount}}</view>
        </view>
      </view>
    </view>

    <view class="footer-placeholder"></view>
  </scroll-view>

  <view class="footer-bar safe-area-bottom" wx:if="{{order.status !== 'cancelled'}}">
    <view class="footer-actions">
      <view class="btn-text" wx:if="{{order.status === 'pending'}}" bindtap="cancelOrder">取消订单</view>
      <view class="btn-text" wx:if="{{order.status === 'completed'}}" bindtap="reorder">再次购买</view>
      <view class="btn-text" wx:if="{{order.status === 'completed'}}" bindtap="goReview">评价</view>
      <view class="btn-primary" wx:if="{{order.status === 'pending'}}" bindtap="payOrder">立即付款</view>
      <view class="btn-secondary" wx:if="{{order.status === 'shipped'}}" bindtap="confirmReceive">确认收货</view>
      <view class="btn-secondary" wx:if="{{order.status === 'paid'}}" bindtap="contactService">联系客服</view>
    </view>
  </view>
</view>