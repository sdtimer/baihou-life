.page {
  min-height: 100vh;
  background: var(--color-bg-base);
  padding-bottom: calc(100rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.banner {
  position: relative;
  height: 480rpx;
  background: linear-gradient(135deg, var(--color-brand-primary) 0%, #5A4A3A 50%, var(--color-brand-accent) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.06) 0%, transparent 40%);
}

.banner-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 40rpx,
    rgba(255, 255, 255, 0.02) 40rpx,
    rgba(255, 255, 255, 0.02) 80rpx
  );
}

.banner-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.brand-name {
  font-size: 64rpx;
  font-weight: 300;
  color: #FFFFFF;
  letter-spacing: 16rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.brand-tagline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 6rpx;
  font-weight: 300;
}

.quick-entry {
  display: flex;
  gap: 16rpx;
}

.entry-item {
  flex: 1;
  padding: 32rpx 24rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg);
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  box-shadow: var(--shadow-1);
}

.entry-item.active {
  background: var(--color-brand-primary);
  border-color: var(--color-brand-primary);
}

.entry-item.active .entry-title,
.entry-item.active .entry-subtitle {
  color: #FFFFFF;
}

.entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.entry-subtitle {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.section {
  padding: 48rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.section-left {
  display: flex;
  align-items: baseline;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 2rpx;
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-left: 16rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.section-more {
  font-size: 26rpx;
  color: var(--color-brand-primary);
  font-weight: 500;
}

.section-more::after {
  content: ' >';
  font-size: 24rpx;
}

.region-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.region-item {
  padding: 18rpx 36rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border-default);
  transition: all 0.2s ease;
}

.region-item.active {
  background: var(--color-brand-primary);
  color: #FFFFFF;
  border-color: var(--color-brand-primary);
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.category-item:active {
  transform: scale(0.98);
}

.category-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--color-brand-primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.category-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 4rpx;
  position: relative;
}

.category-icon-living {
  background: var(--color-brand-primary);
  border-radius: 6rpx;
}

.category-icon-bedroom::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 24rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 6rpx;
}

.category-icon-dining {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-radius: 50%;
}

.category-icon-outdoor {
  width: 0;
  height: 0;
  border-left: 22rpx solid transparent;
  border-right: 22rpx solid transparent;
  border-bottom: 36rpx solid var(--color-brand-primary);
}

.category-name {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.scene-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.scene-card {
  display: inline-block;
  width: 540rpx;
  margin-right: 24rpx;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.scene-card:active {
  transform: scale(0.98);
}

.scene-image {
  width: 100%;
  height: 360rpx;
}

.scene-info {
  padding: 24rpx 28rpx;
}

.scene-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.scene-desc {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 12rpx;
}

.scene-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price-current {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-brand-primary);
}

.price-original {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  text-decoration: line-through;
}

.cta-card {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--color-brand-primary-soft) 0%, var(--color-brand-accent-soft) 100%);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cta-content {
  flex: 1;
}

.cta-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.cta-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.cta-card .btn {
  width: 200rpx;
  flex-shrink: 0;
  margin-left: 32rpx;
}

.footer {
  padding: 64rpx 32rpx;
  text-align: center;
  background: linear-gradient(180deg, var(--color-bg-base) 0%, var(--color-surface-muted) 100%);
}

.footer-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 4rpx;
}

.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--color-border-default);
  border-radius: var(--radius-md);
  background: var(--color-surface-base);
  transition: border-color 0.2s ease;
}

.picker-trigger:active {
  border-color: var(--color-brand-primary);
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker-placeholder {
  color: var(--color-text-tertiary);
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid var(--color-text-tertiary);
  border-bottom: 3rpx solid var(--color-text-tertiary);
  transform: rotate(45deg);
}

.picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  visibility: hidden;
  transition: visibility 0.3s ease;
}

.picker-popup--visible {
  visibility: visible;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.picker-popup--visible .picker-mask {
  opacity: 1;
}

.picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.picker-popup--visible .picker-panel {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
  flex-shrink: 0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-cancel {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 16rpx;
}

.picker-confirm {
  font-size: 28rpx;
  color: var(--color-brand-primary);
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.picker-body {
  flex: 1;
  overflow: hidden;
}

.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-default);
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background: var(--color-bg-base);
}

.picker-option--active {
  background: var(--color-brand-primary-soft);
}

.picker-option__text {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.picker-option--active .picker-option__text {
  color: var(--color-brand-primary);
  font-weight: 500;
}

.picker-option__check {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.picker-option__check::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 12rpx;
  height: 22rpx;
  border: 4rpx solid var(--color-brand-primary);
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}