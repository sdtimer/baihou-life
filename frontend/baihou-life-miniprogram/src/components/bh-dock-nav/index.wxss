.bh-dock-nav {
  position: sticky;
  bottom: 24rpx;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6rpx;
  margin-top: 32rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 1rpx solid rgba(221, 213, 204, 0.80);
  box-shadow:
    0 20rpx 50rpx rgba(64, 45, 25, 0.14),
    0 6rpx 16rpx rgba(64, 45, 25, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(24rpx);
}

.bh-dock-nav__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  min-height: 92rpx;
  border-radius: 999rpx;
  color: #a09890;
  transition: all 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.bh-dock-nav__icon {
  font-size: 34rpx;
  line-height: 1;
  transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.bh-dock-nav__label {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 500;
}

.bh-dock-nav__item--active {
  background: linear-gradient(145deg, rgba(111, 90, 69, 0.16) 0%, rgba(125, 138, 99, 0.12) 100%);
  color: #6f5a45;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.5);
}

.bh-dock-nav__item--active .bh-dock-nav__label {
  font-weight: 700;
}

.bh-dock-nav__item--active .bh-dock-nav__icon {
  transform: scale(1.15);
}
