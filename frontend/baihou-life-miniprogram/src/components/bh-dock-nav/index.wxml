<view class="bh-dock-nav">
  <view
    wx:for="{{items}}"
    wx:key="key"
    class="bh-dock-nav__item {{current === item.key ? 'bh-dock-nav__item--active' : ''}}"
    data-key="{{item.key}}"
    data-url="{{item.url}}"
    bindtap="navigate"
  >
    <text class="bh-dock-nav__icon">{{item.icon}}</text>
    <text class="bh-dock-nav__label">{{item.label}}</text>
  </view>
</view>
