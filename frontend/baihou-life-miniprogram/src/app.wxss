page {
  --bh-color-primary: #6f5a45;
  --bh-color-primary-strong: #5f4c3a;
  --bh-color-primary-light: #f3ede5;
  --bh-color-accent: #7d8a63;
  --bh-color-accent-light: #eef1e8;
  --bh-color-gold: #c9a96e;
  --bh-color-bg: #f7f4ef;
  --bh-color-surface: #ffffff;
  --bh-color-surface-muted: #f2eee8;
  --bh-color-text: #2f2a26;
  --bh-color-text-secondary: #6c655e;
  --bh-color-text-tertiary: #9b938b;
  --bh-color-border: #ddd5cc;
  --bh-color-border-strong: #bdaf9f;
  --bh-color-success: #3e7b57;
  --bh-color-warning: #b9852b;
  --bh-color-error: #b74d45;
  --bh-color-info: #4e6a7d;
  --bh-radius-card: 28rpx;
  --bh-radius-pill: 999rpx;
  --bh-page-gutter: 32rpx;
  --bh-shadow-soft: 0 8rpx 24rpx rgba(64, 45, 25, 0.07), 0 2rpx 6rpx rgba(64, 45, 25, 0.04);
  --bh-shadow-card: 0 16rpx 40rpx rgba(64, 45, 25, 0.10), 0 4rpx 10rpx rgba(64, 45, 25, 0.05);
  --bh-shadow-float: 0 20rpx 60rpx rgba(64, 45, 25, 0.16), 0 6rpx 16rpx rgba(64, 45, 25, 0.08);
  background: var(--bh-color-bg);
  color: var(--bh-color-text);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

view, text, button, input, textarea, scroll-view, swiper, swiper-item, navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 80% 0%, rgba(125, 138, 99, 0.14) 0%, transparent 50%),
    radial-gradient(ellipse at 20% 100%, rgba(201, 169, 110, 0.08) 0%, transparent 45%),
    linear-gradient(180deg, #fcf9f5 0%, #f7f4ef 30%, #f3ede5 100%);
  color: var(--bh-color-text);
}

.page-content {
  padding: 20rpx var(--bh-page-gutter) 56rpx;
}

/* ── 卡片 ─────────────────────────────────────────── */
.bh-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(221, 213, 204, 0.75);
  border-radius: var(--bh-radius-card);
  box-shadow: var(--bh-shadow-card);
  backdrop-filter: blur(24rpx);
}

/* ── 分区 ─────────────────────────────────────────── */
.bh-section {
  margin-top: 28rpx;
}

/* ── 排版 ─────────────────────────────────────────── */
.bh-title {
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--bh-color-text);
}

.bh-subtitle {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--bh-color-text-secondary);
}

/* ── 主按钮 ─────────────────────────────────────────── */
.bh-button-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 0 36rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8a7260 0%, #6f5a45 50%, #5c4a35 100%);
  color: #fffdf8;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  box-shadow: 0 12rpx 32rpx rgba(95, 76, 58, 0.30), 0 3rpx 8rpx rgba(95, 76, 58, 0.15);
  position: relative;
  overflow: hidden;
}

.bh-button-primary::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, transparent 50%);
  border-radius: inherit;
}

/* ── 次按钮 ─────────────────────────────────────────── */
.bh-button-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(111, 90, 69, 0.28);
  background: rgba(255, 255, 255, 0.85);
  color: var(--bh-color-primary);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  box-shadow: 0 4rpx 12rpx rgba(111, 90, 69, 0.08);
}

/* ── Pill 标签 ─────────────────────────────────────── */
.bh-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: var(--bh-radius-pill);
  background: rgba(255, 255, 255, 0.88);
  border: 1.5rpx solid rgba(221, 213, 204, 0.85);
  color: var(--bh-color-text-secondary);
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
  box-shadow: 0 2rpx 6rpx rgba(64, 45, 25, 0.04);
}

.bh-pill--active {
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.13), rgba(111, 90, 69, 0.07));
  border-color: rgba(111, 90, 69, 0.30);
  color: var(--bh-color-primary);
  font-weight: 600;
  box-shadow: 0 3rpx 10rpx rgba(111, 90, 69, 0.12);
}

/* ── Meta & Price ─────────────────────────────────── */
.bh-meta {
  font-size: 24rpx;
  color: var(--bh-color-text-tertiary);
}

.bh-price {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.bh-price__main {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--bh-color-primary);
  letter-spacing: -0.01em;
}

.bh-price__secondary {
  font-size: 24rpx;
  text-decoration: line-through;
  color: var(--bh-color-text-tertiary);
}

/* ── 骨架屏 ─────────────────────────────────────────── */
.bh-skeleton {
  overflow: hidden;
  position: relative;
  background: linear-gradient(90deg,
    rgba(242, 238, 232, 0.85) 0%,
    rgba(255, 255, 255, 0.92) 50%,
    rgba(242, 238, 232, 0.85) 100%
  );
  background-size: 300% 100%;
  animation: bh-skeleton 1.8s ease-in-out infinite;
}

.bh-topbar-spacer {
  height: 176rpx;
}

/* ── 分割线 ─────────────────────────────────────────── */
.bh-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(221, 213, 204, 0.8), transparent);
  margin: 20rpx 0;
}

/* ── 入场动画 ─────────────────────────────────────── */
.bh-fade-in {
  animation: bh-fade-in 0.32s ease-out both;
}

.bh-slide-up {
  animation: bh-slide-up 0.36s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

/* ── Keyframes ──────────────────────────────────── */
@keyframes bh-skeleton {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

@keyframes bh-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes bh-slide-up {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
