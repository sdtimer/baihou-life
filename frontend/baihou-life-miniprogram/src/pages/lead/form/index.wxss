/* ── 留资表单 ────────────────────────────────────── */
.form-card {
  display: grid;
  gap: 0;
  padding: 0;
  overflow: hidden;
}

/* 产品上下文 */
.form-card__context {
  margin: 0;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.07), rgba(125, 138, 99, 0.05));
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.45);
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 23rpx;
  color: #6f5a45;
  font-weight: 500;
}

.form-card__context::before {
  content: '◈';
  font-size: 20rpx;
  color: #7d8a63;
}

/* 表单行 */
.form-row {
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.45);
}

.form-row:last-of-type {
  border-bottom: none;
}

.form-label {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.03em;
  color: #b0a89e;
  margin-bottom: 10rpx;
}

.form-card__input {
  width: 100%;
  height: 72rpx;
  padding: 0 4rpx;
  background: transparent;
  font-size: 28rpx;
  color: #2f2a26;
  border: none;
}

.form-card__textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 0 4rpx;
  background: transparent;
  font-size: 27rpx;
  color: #2f2a26;
  line-height: 1.6;
  border: none;
}

/* 提交按钮 */
.form-submit-row {
  padding: 24rpx 28rpx;
}

.form-submit-row .bh-button-primary {
  width: 100%;
}
