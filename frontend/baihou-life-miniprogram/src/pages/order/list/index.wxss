.nav-tabs {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.nav-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #7c746d;
  font-size: 24rpx;
  border: 1rpx solid rgba(221, 213, 204, 0.75);
}

.nav-tab.active {
  background: #6f5a45;
  color: #ffffff;
  border-color: #6f5a45;
}

.order-list {
  display: grid;
  gap: 16rpx;
  margin-top: 22rpx;
}

.order-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--bh-shadow-soft);
  border-left: 8rpx solid #d4ccc4;
}

.order-card--pending_pay {
  border-left-color: #c69238;
}

.order-card--paid,
.order-card--processing {
  border-left-color: #7d8a63;
}

.order-card--shipped {
  border-left-color: #5f8a74;
}

.order-card--completed {
  border-left-color: #9ca97d;
}

.order-card--closed {
  border-left-color: #c0b8b0;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 24rpx 18rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.45);
}

.order-no {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #7c746d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
  color: #6f5a45;
}

.order-body {
  padding: 22rpx 24rpx 26rpx;
}

.order-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2a26;
  line-height: 1.35;
}

.order-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #a09890;
}

.order-amount {
  margin-top: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #6f5a45;
}
