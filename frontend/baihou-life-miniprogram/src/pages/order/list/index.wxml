<bh-shell title="我的订单" subtitle="按状态查看履约进度，保持简单清晰。">
  <view class="nav-tabs">
    <view
      wx:for="{{tabList}}"
      wx:key="value"
      class="nav-tab {{currentTab === item.value ? 'active' : ''}}"
      bindtap="onTabChange"
      data-value="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <bh-empty wx:if="{{loading}}" title="订单加载中" subtitle="正在同步支付与履约状态。" />

  <view wx:elif="{{filteredRows.length}}" class="order-list">
    <view
      wx:for="{{filteredRows}}"
      wx:key="order_id"
      class="order-card order-card--{{item.status}}"
      data-id="{{item.order_id}}"
      bindtap="openDetail"
    >
      <view class="order-header">
        <view class="order-no">订单号：{{item.order_no}}</view>
        <view class="order-status">{{item.status_text}}</view>
      </view>

      <view class="order-body">
        <view class="order-name">{{item.product_name}}</view>
        <view class="order-meta">{{item.created_at}} · {{item.region_name}}</view>
        <view class="order-amount">¥{{item.pay_amount}}</view>
      </view>
    </view>
  </view>

  <bh-empty wx:else title="暂无订单" subtitle="完成下单后，这里会展示支付、发货和完成状态。" />

</bh-shell>
