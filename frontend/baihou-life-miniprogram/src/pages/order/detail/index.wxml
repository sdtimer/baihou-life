<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-content">
      <view class="nav-back" bindtap="goBack">
        <view class="back-icon"></view>
      </view>
      <view class="nav-title">订单详情</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <bh-empty wx:if="{{loading}}" title="订单详情加载中" subtitle="正在同步订单状态。" />
  <bh-empty wx:elif="{{!detail}}" title="订单不存在" subtitle="请返回订单列表重新进入。" />

  <view wx:else class="page-body">
    <view class="status-card status-card--{{detail.status}}">
      <view class="status-icon"></view>
      <view class="status-text">{{detail.status_text}}</view>
      <view class="status-desc">{{detail.created_at}}</view>
    </view>

    <view class="section">
      <view class="section-title">订单信息</view>
      <view class="info-list">
        <view class="info-item">
          <view class="info-label">订单编号</view>
          <view class="info-value">{{detail.order_no}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">商品摘要</view>
          <view class="info-value">{{detail.product_summary}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">服务区域</view>
          <view class="info-value">{{detail.region_name}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">下单时间</view>
          <view class="info-value">{{detail.created_at}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">订单项</view>
      <view class="info-list">
        <view class="info-item" wx:for="{{detail.items}}" wx:key="item_id">
          <view>
            <view class="info-label">{{item.product_name}}</view>
            <view class="status-desc">数量 {{item.quantity}} · 单价 ¥{{item.unit_price}}</view>
          </view>
          <view class="info-value">¥{{item.line_amount}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">费用明细</view>
      <view class="amount-card">
        <view class="info-item">
          <view class="info-label">商品件数</view>
          <view class="info-value">{{detail.item_count}}</view>
        </view>
        <view class="amount-label">实付金额</view>
        <view class="amount-value">¥{{detail.pay_amount}}</view>
      </view>
    </view>

    <view class="footer-bar" wx:if="{{detail.status === 'pending_pay'}}">
      <button class="btn-primary" loading="{{paying}}" bindtap="payNow">{{paying ? '支付处理中' : '立即支付'}}</button>
    </view>
  </view>
</view>
