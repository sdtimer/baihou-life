.page {
  min-height: 100vh;
  background: var(--bh-page-bg);
}

.nav-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.7);
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #2f2a26;
  border-bottom: 4rpx solid #2f2a26;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2a26;
}

.nav-placeholder {
  width: 72rpx;
}

.page-body {
  padding: 0 24rpx calc(140rpx + env(safe-area-inset-bottom));
}

.status-card {
  margin-top: 24rpx;
  padding: 42rpx 32rpx;
  border-radius: 28rpx;
  text-align: center;
  color: #ffffff;
}

.status-card--pending_pay {
  background: linear-gradient(135deg, #c69238 0%, #c77a4d 100%);
}

.status-card--paid,
.status-card--processing {
  background: linear-gradient(135deg, #6f5a45 0%, #7d8a63 100%);
}

.status-card--shipped {
  background: linear-gradient(135deg, #5f8a74 0%, #7d8a63 100%);
}

.status-card--completed {
  background: linear-gradient(135deg, #7d8a63 0%, #9ca97d 100%);
}

.status-card--closed {
  background: linear-gradient(135deg, #b0a89e 0%, #c8c0b8 100%);
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
}

.section {
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--bh-shadow-soft);
}

.section-title {
  padding: 24rpx 24rpx 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2f2a26;
}

.info-list {
  padding: 0 24rpx 24rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.42);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 24rpx;
  color: #9b938b;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #2f2a26;
  line-height: 1.5;
  word-break: break-all;
}

.amount-card {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.06), rgba(125, 138, 99, 0.04));
  border: 1rpx solid rgba(221, 213, 204, 0.45);
}

.amount-label {
  font-size: 24rpx;
  color: #9b938b;
  margin-bottom: 10rpx;
}

.amount-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #6f5a45;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(221, 213, 204, 0.7);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  background: #6f5a45;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}
