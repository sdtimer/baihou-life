.topbar {
  margin-bottom: 28rpx;
}

.topbar-search {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.topbar-search__input {
  flex: 1;
  height: 86rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(221, 213, 204, 0.8);
  font-size: 27rpx;
  color: #2f2a26;
}

.topbar-search__button {
  min-width: 136rpx;
  height: 86rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #6f5a45;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.topbar-region {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 26rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(221, 213, 204, 0.76);
}

.topbar-region__label {
  font-size: 24rpx;
  color: #6f5a45;
  font-weight: 600;
}

.topbar-region__arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #8b8279;
  border-bottom: 3rpx solid #8b8279;
  transform: rotate(45deg);
}

.brand-panel {
  position: relative;
  margin-bottom: 26rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #64503f 0%, #7b6856 45%, #7a8860 100%);
}

.brand-panel__glow {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.16) 0%, transparent 36%),
    radial-gradient(circle at 85% 78%, rgba(250, 245, 239, 0.12) 0%, transparent 32%);
}

.brand-panel__content {
  position: relative;
  z-index: 1;
  padding: 42rpx 34rpx 40rpx;
}

.brand-panel__eyebrow {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: rgba(255, 255, 255, 0.76);
  margin-bottom: 18rpx;
}

.brand-panel__title {
  font-size: 60rpx;
  line-height: 1.1;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 18rpx;
}

.brand-panel__desc {
  font-size: 26rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.88);
}

.brand-panel__actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 30rpx;
}

.brand-chip {
  min-height: 60rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 23rpx;
  display: inline-flex;
  align-items: center;
}

.brand-link {
  font-size: 25rpx;
  color: #edf4df;
  font-weight: 600;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.quick-card {
  min-height: 228rpx;
  padding: 28rpx 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  box-shadow: var(--bh-shadow-soft);
}

.quick-card__icon {
  width: 58rpx;
  height: 58rpx;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  position: relative;
}

.quick-card__icon--product {
  background: rgba(111, 90, 69, 0.14);
}

.quick-card__icon--product::before {
  content: '';
  position: absolute;
  inset: 12rpx;
  border: 3rpx solid #6f5a45;
  border-radius: 10rpx;
}

.quick-card__icon--appointment {
  background: rgba(125, 138, 99, 0.18);
}

.quick-card__icon--appointment::before {
  content: '';
  position: absolute;
  inset: 14rpx;
  border: 3rpx solid #5d6e4a;
  border-radius: 50%;
}

.quick-card__icon--designer {
  background: rgba(201, 169, 110, 0.18);
}

.quick-card__icon--designer::before {
  content: '';
  position: absolute;
  inset: 15rpx;
  border: 3rpx solid #8a6a2d;
  border-radius: 50%;
}

.quick-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2a26;
  margin-bottom: 10rpx;
}

.quick-card__desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #8e857d;
}

.feed-section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2f2a26;
}

.section-subtitle {
  font-size: 24rpx;
  color: #9b938b;
  margin-top: 8rpx;
}

.section-more {
  font-size: 26rpx;
  color: #6f5a45;
  font-weight: 500;
}

.feed-columns {
  display: flex;
  gap: 16rpx;
}

.feed-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feed-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: var(--bh-shadow-soft);
}

.feed-card__image {
  width: 100%;
  display: block;
  background: #f0ebe4;
}

.feed-card__body {
  padding: 22rpx 20rpx 24rpx;
}

.feed-card__title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
  color: #2f2a26;
  margin-bottom: 8rpx;
}

.feed-card__subtitle {
  font-size: 22rpx;
  color: #9b938b;
  margin-bottom: 14rpx;
}

.feed-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.feed-card__tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f0ebe4;
  color: #7c746d;
  font-size: 20rpx;
}

.feed-card__price {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
}

.feed-card__price-label {
  font-size: 20rpx;
  color: #8f857a;
}

.feed-card__price-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #6f5a45;
}

.feed-card__price-unit {
  font-size: 20rpx;
  color: #8f857a;
}

.feed-card__price--ghost {
  font-size: 22rpx;
  color: #9b938b;
}

.story-card {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.1), rgba(125, 138, 99, 0.12));
}

.story-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2a26;
  margin-bottom: 12rpx;
}

.story-card__desc {
  font-size: 24rpx;
  line-height: 1.8;
  color: #7c746d;
}

.loading-block {
  padding: 40rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: #9b938b;
}

.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(221, 213, 204, 0.8);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #2f2a26;
}

.picker-placeholder {
  color: #9b938b;
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #9b938b;
  border-bottom: 3rpx solid #9b938b;
  transform: rotate(45deg);
}

.picker-popup {
  position: fixed;
  inset: 0;
  z-index: 9999;
  visibility: hidden;
}

.picker-popup--visible {
  visibility: visible;
}

.picker-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.6);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2f2a26;
}

.picker-cancel,
.picker-confirm {
  font-size: 28rpx;
  padding: 8rpx 12rpx;
}

.picker-cancel {
  color: #7c746d;
}

.picker-confirm {
  color: #6f5a45;
  font-weight: 600;
}

.picker-body {
  flex: 1;
}

.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.4);
}

.picker-option--active {
  background: rgba(111, 90, 69, 0.08);
}

.picker-option__text {
  font-size: 30rpx;
  color: #2f2a26;
}

.picker-option__check {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.picker-option__check::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 12rpx;
  height: 22rpx;
  border: 4rpx solid #6f5a45;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}
