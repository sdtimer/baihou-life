<bh-shell title="柏厚生活" subtitle="以区域化选品、空间方案和场景灵感，组织更轻的家居决策。">
  <view class="banner">
    <view class="banner-bg"></view>
    <view class="banner-content">
      <view class="brand-name">柏厚生活</view>
      <view class="brand-tagline">Baihou Life</view>
      <view class="banner-actions">
        <button class="{{isDesigner ? 'role-button role-button--designer' : 'role-button'}}" bindtap="goAuth">
          {{isDesigner ? '设计师身份已启用' : '登录查看专属价'}}
        </button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-left">
        <view class="section-title">选择区域</view>
        <view class="section-subtitle">Region</view>
      </view>
    </view>
    <view class="picker-trigger" bindtap="showRegionPicker">
      <view class="picker-value {{currentRegion ? '' : 'picker-placeholder'}}">
        {{regionLabel || '请选择服务区域'}}
      </view>
      <view class="picker-arrow"></view>
    </view>
  </view>

  <view class="section section--compact">
    <view class="quick-entry">
      <view class="entry-item {{currentTab === 'category' ? 'active' : ''}}" bindtap="onTabChange" data-tab="category">
        <view class="entry-title">品类</view>
        <view class="entry-subtitle">Category</view>
      </view>
      <view class="entry-item {{currentTab === 'space' ? 'active' : ''}}" bindtap="onTabChange" data-tab="space">
        <view class="entry-title">空间</view>
        <view class="entry-subtitle">Space</view>
      </view>
      <view class="entry-item {{currentTab === 'scene' ? 'active' : ''}}" bindtap="onTabChange" data-tab="scene">
        <view class="entry-title">场景</view>
        <view class="entry-subtitle">Scene</view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{currentTab === 'scene'}}">
    <view class="section-header">
      <view class="section-left">
        <view class="section-title">场景切换</view>
        <view class="section-subtitle">Mood</view>
      </view>
    </view>
    <scroll-view scroll-x class="home-scenes">
      <view class="home-scenes__track">
        <view
          wx:for="{{sceneTabs}}"
          wx:key="value"
          class="scene-pill {{activeScene === item.value ? 'scene-pill--active' : ''}}"
          data-scene="{{item.value}}"
          bindtap="changeScene"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section" wx:if="{{currentTab === 'space'}}">
    <view class="section-header">
      <view class="section-left">
        <view class="section-title">空间切换</view>
        <view class="section-subtitle">Space</view>
      </view>
    </view>
    <scroll-view scroll-x class="home-scenes">
      <view class="home-scenes__track">
        <view
          wx:for="{{spaceTabs}}"
          wx:key="value"
          class="scene-pill {{activeSpace === item.value ? 'scene-pill--active' : ''}}"
          data-space="{{item.value}}"
          bindtap="changeSpace"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section" wx:if="{{currentTab === 'category'}}">
    <view class="section-header">
      <view class="section-left">
        <view class="section-title">品类切换</view>
        <view class="section-subtitle">Category</view>
      </view>
    </view>
    <scroll-view scroll-x class="home-scenes">
      <view class="home-scenes__track">
        <view
          class="scene-pill {{!activeCategoryId ? 'scene-pill--active' : ''}}"
          data-category-id=""
          bindtap="changeCategory"
        >
          全部
        </view>
        <view
          wx:for="{{categoryTabs}}"
          wx:key="category_id"
          class="scene-pill {{activeCategoryId === item.category_id ? 'scene-pill--active' : ''}}"
          data-category-id="{{item.category_id}}"
          bindtap="changeCategory"
        >
          {{item.category_name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-left">
        <view class="section-title">{{currentSectionTitle}}</view>
        <view class="section-subtitle">{{currentSectionSubtitle}}</view>
      </view>
      <view class="section-more" bindtap="goProductList">查看全部</view>
    </view>
    <bh-empty wx:if="{{errorMessage}}" title="首页加载失败" subtitle="{{errorMessage}}" />
    <scroll-view wx:else class="scene-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        class="scene-card"
        wx:for="{{heroProducts}}"
        wx:key="id"
        bindtap="openDetail"
        data-id="{{item.id}}"
      >
        <image wx:if="{{item.cover_image}}" class="scene-image" src="{{item.cover_image}}" mode="aspectFill" />
        <view wx:else class="scene-image scene-image--placeholder">
          <view class="scene-image__icon"></view>
          <view class="scene-image__text">{{item.category_name}}</view>
        </view>
        <view class="scene-info">
          <view class="scene-name">{{item.name}}</view>
          <view class="scene-desc">{{item.brand}} · {{item.category_name}}</view>
          <view class="scene-price">
            <text class="price-current">¥{{isDesigner && item.designer_price ? item.designer_price : item.guide_price}}</text>
            <text class="price-original" wx:if="{{isDesigner && item.guide_price}}">¥{{item.guide_price}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="cta-card">
      <view class="cta-content">
        <view class="cta-title">免费获取设计方案</view>
        <view class="cta-desc">专业设计师一对一服务，围绕当前城市提供更落地的方案。</view>
      </view>
      <view class="cta-button" bindtap="goAppointment">立即预约</view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-text">柏厚生活 · 自然与人文的融合</view>
  </view>

  <view class="picker-popup {{pickerVisible ? 'picker-popup--visible' : ''}}" catchtouchmove="preventMove">
    <view class="picker-mask" bindtap="closePicker"></view>
    <view class="picker-panel">
      <view class="picker-header">
        <view class="picker-cancel" bindtap="closePicker">取消</view>
        <view class="picker-title">选择区域</view>
        <view class="picker-confirm" bindtap="confirmPicker">确定</view>
      </view>
      <scroll-view scroll-y class="picker-body">
        <view
          wx:for="{{regionOptions}}"
          wx:key="region_id"
          class="picker-option {{tempPickerValue === item.region_id ? 'picker-option--active' : ''}}"
          data-value="{{item.region_id}}"
          bindtap="selectPickerOption"
        >
          <view class="picker-option__text">{{item.region_name}}</view>
          <view class="picker-option__check" wx:if="{{tempPickerValue === item.region_id}}"></view>
        </view>
      </scroll-view>
    </view>
  </view>

</bh-shell>
