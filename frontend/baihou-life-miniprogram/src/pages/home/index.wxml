<bh-shell title="柏厚生活" subtitle="品牌入口、区域选品与高质量商品流，在首页轻量完成。">
  <view class="topbar">
    <view class="topbar-search" bindtap="openSearch">
      <input
        class="topbar-search__input"
        placeholder="搜索品牌、品类或产品名"
        value="{{searchKeyword}}"
        bindinput="bindSearchKeyword"
        bindconfirm="goProductList"
        confirm-type="search"
      />
      <view class="topbar-search__button" bindtap="goProductList">搜索</view>
    </view>
    <view class="topbar-region" bindtap="showRegionPicker">
      <view class="topbar-region__label">{{regionLabel || '选择城市'}}</view>
      <view class="topbar-region__arrow"></view>
    </view>
  </view>

  <view class="brand-panel">
    <view class="brand-panel__glow"></view>
    <view class="brand-panel__content">
      <view class="brand-panel__eyebrow">Baihou Life</view>
      <view class="brand-panel__title">柏厚生活</view>
      <view class="brand-panel__desc">围绕城市交付能力，组织主材、定制与设计服务，先用高质量主图筛出值得看的商品。</view>
      <view class="brand-panel__actions">
        <view class="brand-chip">{{isDesigner ? '设计师模式已启用' : (isLoggedIn ? '客户身份浏览中' : '游客浏览中')}}</view>
        <view class="brand-link" bindtap="goAuth">{{isLoggedIn ? '切换身份' : '登录查看价格'}}</view>
      </view>
    </view>
  </view>

  <view class="quick-grid">
    <view class="quick-card" bindtap="goProductList">
      <view class="quick-card__icon quick-card__icon--product"></view>
      <view class="quick-card__title">全部产品</view>
      <view class="quick-card__desc">进入选品中心看完整筛选</view>
    </view>
    <view class="quick-card" bindtap="goAppointment">
      <view class="quick-card__icon quick-card__icon--appointment"></view>
      <view class="quick-card__title">预约服务</view>
      <view class="quick-card__desc">围绕当前城市预约量尺与设计</view>
    </view>
    <view class="quick-card" bindtap="openDesignerEntry">
      <view class="quick-card__icon quick-card__icon--designer"></view>
      <view class="quick-card__title">设计师入口</view>
      <view class="quick-card__desc">查看专属价格与高清素材下载</view>
    </view>
  </view>

  <view class="feed-section">
    <view class="section-header">
      <view>
        <view class="section-title">本地上新</view>
        <view class="section-subtitle">仅展示当前区域已上架且有主图的商品</view>
      </view>
      <view class="section-more" bindtap="goProductList">查看全部</view>
    </view>

    <bh-empty wx:if="{{errorMessage}}" title="首页加载失败" subtitle="{{errorMessage}}" />

    <view wx:elif="{{loading}}" class="loading-block">
      <view class="loading-text">正在加载精选内容...</view>
    </view>

    <view wx:elif="{{feedLeft.length || feedRight.length}}" class="feed-columns">
      <view class="feed-column">
        <view class="feed-card" wx:for="{{feedLeft}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
          <image class="feed-card__image" src="{{item.cover_image}}" mode="widthFix" />
          <view class="feed-card__body">
            <view class="feed-card__title">{{item.title}}</view>
            <view class="feed-card__subtitle">{{item.subtitle}}</view>
            <view class="feed-card__tags" wx:if="{{item.tags.length}}">
              <view class="feed-card__tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</view>
            </view>
            <view wx:if="{{item.price.visible}}" class="feed-card__price">
              <text class="feed-card__price-label">{{item.price.label}}</text>
              <text class="feed-card__price-value">¥{{item.price.amount}}</text>
              <text class="feed-card__price-unit">{{item.price.unit}}</text>
            </view>
            <view wx:else class="feed-card__price feed-card__price--ghost">登录后查看价格</view>
          </view>
        </view>
      </view>
      <view class="feed-column">
        <view class="feed-card" wx:for="{{feedRight}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
          <image class="feed-card__image" src="{{item.cover_image}}" mode="widthFix" />
          <view class="feed-card__body">
            <view class="feed-card__title">{{item.title}}</view>
            <view class="feed-card__subtitle">{{item.subtitle}}</view>
            <view class="feed-card__tags" wx:if="{{item.tags.length}}">
              <view class="feed-card__tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</view>
            </view>
            <view wx:if="{{item.price.visible}}" class="feed-card__price">
              <text class="feed-card__price-label">{{item.price.label}}</text>
              <text class="feed-card__price-value">¥{{item.price.amount}}</text>
              <text class="feed-card__price-unit">{{item.price.unit}}</text>
            </view>
            <view wx:else class="feed-card__price feed-card__price--ghost">登录后查看价格</view>
          </view>
        </view>
      </view>
    </view>

    <bh-empty wx:else title="当前区域暂无上新" subtitle="换一个城市，或稍后再回来看看。" />
  </view>

  <view class="story-card">
    <view class="story-card__title">品牌说明</view>
    <view class="story-card__desc">柏厚生活用区域可交付商品做发现页，用完整筛选承接选品页，让首页先服务浏览，再服务决策。</view>
  </view>

  <view class="picker-popup {{pickerVisible ? 'picker-popup--visible' : ''}}" catchtouchmove="preventMove">
    <view class="picker-mask" bindtap="closePicker"></view>
    <view class="picker-panel">
      <view class="picker-header">
        <view class="picker-cancel" bindtap="closePicker">取消</view>
        <view class="picker-title">选择区域</view>
        <view class="picker-confirm" bindtap="confirmPicker">确定</view>
      </view>
      <scroll-view scroll-y class="picker-body">
        <view
          wx:for="{{regionOptions}}"
          wx:key="region_id"
          class="picker-option {{tempPickerValue === item.region_id ? 'picker-option--active' : ''}}"
          data-value="{{item.region_id}}"
          bindtap="selectPickerOption"
        >
          <view class="picker-option__text">{{item.region_name}}</view>
          <view class="picker-option__check" wx:if="{{tempPickerValue === item.region_id}}"></view>
        </view>
      </scroll-view>
    </view>
  </view>
</bh-shell>
