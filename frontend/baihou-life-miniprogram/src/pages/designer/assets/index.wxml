<bh-shell title="设计师素材" subtitle="下载前先换取临时链接，普通客户不显示高清图下载入口。">
  <bh-empty wx:if="{{loading}}" title="素材加载中" subtitle="正在准备当前商品的高清图片列表。" />
  <bh-empty wx:elif="{{!isDesigner}}" title="当前账号暂无素材权限" subtitle="设计师登录后可查看高清图与原文件下载入口。" />
  <bh-empty wx:elif="{{errorMessage && !product}}" title="素材暂不可访问" subtitle="{{errorMessage}}" />
  <view wx:elif="{{product}}" class="assets-card bh-card">
    <view class="assets-card__name">{{product.name}}</view>
    <view class="assets-card__desc">高清图链接默认 5 分钟内有效，下载动作会写入日志。</view>
    <view wx:if="{{product.download_images.length}}" class="assets-list">
      <view wx:for="{{product.download_images}}" wx:key="media_id" class="assets-item">
        <view>
          <view class="assets-item__title">{{item.name}}</view>
          <view class="assets-item__meta">权限：{{item.access_level}} {{item.file_format ? '· ' + item.file_format : ''}}</view>
        </view>
        <button class="bh-button-secondary" data-media-id="{{item.media_id}}" bindtap="downloadAsset">获取链接</button>
      </view>
    </view>
    <bh-empty wx:else title="当前商品暂无高清图" subtitle="{{errorMessage || '可联系后台继续补充高清图片。'}}" />
  </view>
</bh-shell>
