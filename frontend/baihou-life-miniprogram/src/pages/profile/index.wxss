/* ── 身份卡片 ────────────────────────────────────── */
.profile-hero {
  padding: 28rpx;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(ellipse at 100% 0%, rgba(201, 169, 110, 0.10), transparent 50%),
    rgba(255, 255, 255, 0.94);
}

.profile-hero__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.profile-hero__identity {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

/* 头像外圈 */
.profile-hero__avatar-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, rgba(125, 138, 99, 0.40), rgba(201, 169, 110, 0.40));
  flex-shrink: 0;
}

/* 头像内圈 */
.profile-hero__avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.18), rgba(125, 138, 99, 0.14));
  color: #6f5a45;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-hero__info {
  flex: 1;
  min-width: 0;
}

.profile-hero__name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2a26;
  letter-spacing: -0.01em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-hero__meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.profile-hero__region-tag {
  font-size: 22rpx;
  color: #9b938b;
}

.profile-hero__dot {
  font-size: 22rpx;
  color: #c8c0b8;
}

.profile-hero__role-tag {
  font-size: 22rpx;
  color: #9b938b;
}

.profile-hero__role-tag--designer {
  color: #5d6e4a;
  font-weight: 600;
}

.profile-hero__btn {
  min-height: 68rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* ── 功能格子 ─────────────────────────────────── */
.profile-grid {
  display: grid;
  gap: 16rpx;
}

.profile-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 26rpx;
}

/* 入口图标 */
.profile-entry__icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.profile-entry__icon--brown {
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.12), rgba(111, 90, 69, 0.06));
  border: 1rpx solid rgba(111, 90, 69, 0.15);
  color: #6f5a45;
}

.profile-entry__icon--gold {
  background: linear-gradient(135deg, rgba(201, 169, 110, 0.15), rgba(201, 169, 110, 0.07));
  border: 1rpx solid rgba(201, 169, 110, 0.20);
  color: #a0783a;
}

.profile-entry__icon--green {
  background: linear-gradient(135deg, rgba(125, 138, 99, 0.14), rgba(125, 138, 99, 0.06));
  border: 1rpx solid rgba(125, 138, 99, 0.18);
  color: #5d6e4a;
}

.profile-entry__content {
  flex: 1;
  min-width: 0;
}

.profile-entry__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2a26;
}

.profile-entry__desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #9b938b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-entry__arrow {
  font-size: 34rpx;
  color: #c8c0b8;
  flex-shrink: 0;
}
