.user-header {
  position: relative;
  margin-bottom: 24rpx;
  padding: 36rpx 0 96rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  inset: 0;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #6f5a45 0%, #7d8a63 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.user-avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  margin-right: 22rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.user-tag {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag-accent {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
}

.tag-light {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.88);
}

.header-actions {
  margin-left: 16rpx;
}

.action-btn {
  min-width: 120rpx;
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-card {
  display: flex;
  align-items: center;
  margin: -68rpx 24rpx 24rpx;
  padding: 30rpx 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  box-shadow: var(--bh-shadow-soft);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2f2a26;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9b938b;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(221, 213, 204, 0.7);
}

.menu-card {
  margin: 0 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--bh-shadow-soft);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.45);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.menu-icon-order {
  border: 4rpx solid #6f5a45;
  border-radius: 6rpx;
}

.menu-icon-order::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 14rpx;
  height: 4rpx;
  background: #6f5a45;
  box-shadow: 0 -7rpx 0 #6f5a45, 0 7rpx 0 #6f5a45;
}

.menu-icon-appointment {
  border: 4rpx solid #6f5a45;
  border-radius: 50%;
}

.menu-icon-appointment::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #6f5a45;
}

.menu-icon-user {
  border: 4rpx solid #6f5a45;
  border-radius: 50%;
}

.menu-icon-user::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6f5a45;
}

.menu-icon-user::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 5rpx;
  transform: translateX(-50%);
  width: 18rpx;
  height: 10rpx;
  border-radius: 10rpx 10rpx 6rpx 6rpx;
  background: #6f5a45;
}

.menu-icon-designer {
  border-radius: 50%;
  background: rgba(125, 138, 99, 0.16);
}

.menu-icon-designer::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #5d6e4a;
  border-radius: 50%;
}

.menu-icon-favorite {
  border-radius: 12rpx;
  background: rgba(201, 169, 110, 0.16);
}

.menu-icon-favorite::before,
.menu-icon-favorite::after {
  content: '';
  position: absolute;
  top: 10rpx;
  width: 12rpx;
  height: 20rpx;
  background: #8a6a2d;
  border-radius: 12rpx 12rpx 0 0;
}

.menu-icon-favorite::before {
  left: 8rpx;
  transform: rotate(-45deg);
  transform-origin: right bottom;
}

.menu-icon-favorite::after {
  right: 8rpx;
  transform: rotate(45deg);
  transform-origin: left bottom;
}

.menu-icon-service {
  border: 4rpx solid #6f5a45;
  border-radius: 50%;
}

.menu-icon-service::before {
  content: '?';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  font-weight: 700;
  color: #6f5a45;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #2f2a26;
}

.menu-badge {
  font-size: 22rpx;
  color: #ffffff;
  background: #c77a4d;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #b0a89e;
  border-bottom: 3rpx solid #b0a89e;
  transform: rotate(-45deg);
}

.designer-entry {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(201, 169, 110, 0.16), rgba(125, 138, 99, 0.14));
  border-radius: 24rpx;
}

.designer-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #c9a96e;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.designer-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
}

.designer-content {
  flex: 1;
}

.designer-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #8a6a2d;
  margin-bottom: 4rpx;
}

.designer-desc {
  font-size: 24rpx;
  color: #7c746d;
}

.designer-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #8a6a2d;
  border-bottom: 3rpx solid #8a6a2d;
  transform: rotate(-45deg);
}
