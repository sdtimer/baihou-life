<bh-shell title="我的" subtitle="账户、订单、预约和设计师能力在这里集中查看。">
  <view class="user-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="user-avatar">
        <view class="avatar-text">{{avatarText}}</view>
      </view>
      <view class="user-info" bindtap="goAuth">
        <view class="user-name">{{displayName}}</view>
        <view class="user-tag">
          <view class="tag tag-accent">{{roleText}}</view>
          <view class="tag tag-light">{{region.region_name}}</view>
        </view>
      </view>
      <view class="header-actions">
        <view class="action-btn" bindtap="goAuth">{{authButtonText}}</view>
      </view>
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item" bindtap="openOrdersByStatus" data-status="pending_pay">
      <view class="stat-value">{{orderStats.pending}}</view>
      <view class="stat-label">待付款</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="openOrdersByStatus" data-status="paid">
      <view class="stat-value">{{orderStats.paid}}</view>
      <view class="stat-label">处理中</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="openOrdersByStatus" data-status="shipped">
      <view class="stat-value">{{orderStats.shipped}}</view>
      <view class="stat-label">待收货</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="openOrdersByStatus" data-status="completed">
      <view class="stat-value">{{orderStats.completed}}</view>
      <view class="stat-label">已完成</view>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="openOrders">
      <view class="menu-icon menu-icon-order"></view>
      <view class="menu-text">我的订单</view>
      <view class="menu-badge" wx:if="{{orderStats.total > 0}}">{{orderStats.total}}</view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="openAppointments">
      <view class="menu-icon menu-icon-appointment"></view>
      <view class="menu-text">我的预约</view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goAuth">
      <view class="menu-icon menu-icon-user"></view>
      <view class="menu-text">{{isLoggedIn ? '账号信息' : '立即登录'}}</view>
      <view class="menu-arrow"></view>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" wx:if="{{isDesigner}}" bindtap="openAssets">
      <view class="menu-icon menu-icon-designer"></view>
      <view class="menu-text">设计师素材</view>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="openOrders">
      <view class="menu-icon menu-icon-service"></view>
      <view class="menu-text">服务进度</view>
      <view class="menu-arrow"></view>
    </view>
  </view>

  <view class="designer-entry" wx:if="{{!isDesigner}}" bindtap="goAuth">
    <view class="designer-icon"></view>
    <view class="designer-content">
      <view class="designer-title">成为设计师</view>
      <view class="designer-desc">切换设计师身份，查看专属价格与素材能力</view>
    </view>
    <view class="designer-arrow"></view>
  </view>

</bh-shell>
