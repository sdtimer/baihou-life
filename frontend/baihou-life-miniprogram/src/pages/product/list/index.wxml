<bh-shell title="按区域筛选空间方案" subtitle="品类、空间、场景三轴组合，保持清晰而不过度密集。">
  <view class="product-search bh-card">
    <input placeholder="搜索品牌或产品名" value="{{filters.keyword}}" bindinput="bindKeyword" />
    <button class="bh-button-secondary" bindtap="handleSearch">搜索</button>
  </view>

  <view class="filter-section bh-section">
    <view class="filter-label">品类 · {{currentRegion.region_name}}</view>
    <scroll-view scroll-x class="filter-row">
      <view class="filter-row__track">
        <view
          wx:for="{{categories}}"
          wx:key="category_id"
          class="bh-pill {{filters.category_id === item.category_id ? 'bh-pill--active' : ''}}"
          data-field="category_id"
          data-value="{{item.category_id}}"
          bindtap="activateFilter"
        >
          {{item.category_name}}
        </view>
      </view>
    </scroll-view>

    <view class="filter-label" style="margin-top:16rpx;">空间</view>
    <scroll-view scroll-x class="filter-row">
      <view class="filter-row__track">
        <view
          wx:for="{{spaces}}"
          wx:key="value"
          class="bh-pill {{filters.space === item.value ? 'bh-pill--active' : ''}}"
          data-field="space"
          data-value="{{item.value}}"
          bindtap="activateFilter"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>

    <view class="filter-label" style="margin-top:16rpx;">场景</view>
    <scroll-view scroll-x class="filter-row">
      <view class="filter-row__track">
        <view
          wx:for="{{scenes}}"
          wx:key="value"
          class="bh-pill {{filters.scene === item.value ? 'bh-pill--active' : ''}}"
          data-field="scene"
          data-value="{{item.value}}"
          bindtap="activateFilter"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>

    <view class="filter-label" style="margin-top:16rpx;">排序</view>
    <scroll-view scroll-x class="filter-row">
      <view class="filter-row__track">
        <view
          wx:for="{{sortOptions}}"
          wx:key="value"
          class="bh-pill {{filters.sort_by === item.value ? 'bh-pill--active' : ''}}"
          data-field="sort_by"
          data-value="{{item.value}}"
          bindtap="activateFilter"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
    <button class="bh-button-secondary" style="margin-top: 20rpx;" bindtap="resetFilters">重置筛选</button>
  </view>

  <view wx:if="{{loading}}" class="product-list">
    <view class="bh-card bh-skeleton product-skeleton"></view>
    <view class="bh-card bh-skeleton product-skeleton"></view>
  </view>
  <bh-empty wx:elif="{{errorMessage}}" title="产品加载失败" subtitle="{{errorMessage}}" />
  <view wx:elif="{{products.length}}" class="product-list">
    <bh-product-card wx:for="{{products}}" wx:key="id" item="{{item}}" showDesigner="{{isDesigner}}" bind:tap="openDetail" />
    <view wx:if="{{loadingMore}}" class="bh-meta" style="text-align:center;padding:24rpx 0;">正在加载更多...</view>
    <view wx:elif="{{!pagination.hasMore}}" class="bh-meta" style="text-align:center;padding:24rpx 0;">已经到底了</view>
  </view>
  <bh-empty wx:else title="暂无符合条件的产品" subtitle="换一个场景、空间或区域，再看一组新的方案。" />
  <bh-dock-nav current="product" />
</bh-shell>
