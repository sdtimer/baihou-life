.toolbar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.toolbar-region {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: fit-content;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(221, 213, 204, 0.8);
}

.toolbar-region__text {
  font-size: 26rpx;
  color: #2f2a26;
  font-weight: 600;
}

.toolbar-region__arrow {
  font-size: 18rpx;
  color: #9b938b;
}

.toolbar-search {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-input {
  flex: 1;
  height: 84rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(221, 213, 204, 0.8);
  font-size: 27rpx;
  color: #2f2a26;
}

.top-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.nav-tab {
  flex: 1;
  height: 86rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #7c746d;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-tab.active {
  background: #6f5a45;
  color: #ffffff;
  font-weight: 600;
}

.filter-panel {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: var(--bh-shadow-soft);
}

.filter-panel__header {
  margin-bottom: 20rpx;
}

.filter-panel__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2a26;
  margin-bottom: 8rpx;
}

.filter-panel__hint {
  font-size: 22rpx;
  color: #9b938b;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-chip,
.sub-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f0ebe4;
  color: #7c746d;
  font-size: 24rpx;
}

.category-chip.active,
.sub-tab.active {
  background: #6f5a45;
  color: #ffffff;
}

.sub-tabs {
  white-space: nowrap;
}

.sub-tabs__track {
  display: inline-flex;
  gap: 12rpx;
}

.search-button {
  min-width: 120rpx;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #6f5a45;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sort-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 0 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.sort-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #7c746d;
  font-size: 24rpx;
  border: 1rpx solid rgba(221, 213, 204, 0.7);
}

.sort-pill--active {
  background: #6f5a45;
  color: #ffffff;
  border-color: #6f5a45;
}

.sort-reset {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(125, 138, 99, 0.14);
  color: #5d6e4a;
  font-size: 24rpx;
  font-weight: 600;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.product-card {
  display: flex;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--bh-shadow-soft);
}

.product-image {
  width: 250rpx;
  height: 250rpx;
  background: #f0ebe4;
  flex-shrink: 0;
}

.product-content {
  flex: 1;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 22rpx 22rpx 20rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2a26;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.product-spec {
  font-size: 23rpx;
  color: #9b938b;
  margin-bottom: 14rpx;
}

.product-price-row {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-unit {
  font-size: 22rpx;
  color: #6f5a45;
  font-weight: 500;
}

.price-value {
  font-size: 34rpx;
  color: #6f5a45;
  font-weight: 600;
  margin-left: 2rpx;
}

.price-original {
  font-size: 22rpx;
  color: #b0a89e;
  text-decoration: line-through;
}

.price-ghost {
  font-size: 22rpx;
  color: #9b938b;
}

.product-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #f0ebe4;
  color: #7c746d;
  font-size: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag-success {
  background: rgba(125, 138, 99, 0.14);
  color: #5d6e4a;
}

.product-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
}

.product-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #b0a89e;
  border-bottom: 3rpx solid #b0a89e;
  transform: rotate(-45deg);
}

.loading-block {
  padding: 28rpx 0 36rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: #9b938b;
}

.area-picker-popup {
  position: fixed;
  inset: 0;
  z-index: 1000;
  visibility: hidden;
}

.area-picker-popup.show {
  visibility: visible;
}

.area-picker-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.area-picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.area-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.6);
}

.area-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2f2a26;
}

.area-picker-cancel,
.area-picker-confirm {
  font-size: 28rpx;
  padding: 8rpx 12rpx;
}

.area-picker-cancel {
  color: #7c746d;
}

.area-picker-confirm {
  color: #6f5a45;
  font-weight: 600;
}

.area-picker-body {
  flex: 1;
}

.area-picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.4);
}

.area-picker-option.active {
  background: rgba(111, 90, 69, 0.08);
}

.area-picker-option__text {
  font-size: 30rpx;
  color: #2f2a26;
}

.area-picker-option__check {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.area-picker-option__check::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 12rpx;
  height: 22rpx;
  border: 4rpx solid #6f5a45;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}
