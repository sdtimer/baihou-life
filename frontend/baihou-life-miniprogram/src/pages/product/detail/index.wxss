.page {
  min-height: 100vh;
  background: var(--bh-page-bg);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-bottom: 16rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-left: 24rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.goods-swiper {
  width: 100%;
  height: 750rpx;
}

.goods-swiper__image {
  width: 100%;
  height: 100%;
}

.goods-info {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.96);
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  flex-wrap: wrap;
}

.goods-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 32rpx;
  font-weight: 600;
  color: #6f5a45;
}

.price-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #6f5a45;
}

.price-original {
  font-size: 28rpx;
  color: #b0a89e;
  text-decoration: line-through;
}

.price-unit {
  font-size: 24rpx;
  color: #9b938b;
}

.login-price-hint {
  font-size: 26rpx;
  color: #7c746d;
}

.goods-name {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2a26;
  line-height: 1.4;
}

.goods-desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #6c655e;
  line-height: 1.6;
}

.goods-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f0ebe4;
  color: #7c746d;
}

.tag-success {
  background: rgba(125, 138, 99, 0.14);
  color: #5d6e4a;
}

.section {
  margin-top: 24rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.96);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2a26;
  margin-bottom: 24rpx;
}

.spec-list {
  border-top: 1rpx solid rgba(221, 213, 204, 0.45);
}

.spec-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.45);
}

.spec-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #9b938b;
  flex-shrink: 0;
}

.spec-value {
  flex: 1;
  font-size: 28rpx;
  color: #2f2a26;
}

.detail-content {
  padding: 24rpx;
  background: #f7f4ef;
  border-radius: 22rpx;
}

.detail-text {
  font-size: 28rpx;
  color: #6c655e;
  line-height: 1.8;
}

.detail-hint {
  margin: 24rpx;
  padding: 18rpx 20rpx;
  background: rgba(238, 241, 232, 0.7);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #7d8a63;
  line-height: 1.5;
}

.detail-hint--designer {
  background: rgba(201, 169, 110, 0.12);
  color: #8a6a2d;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(221, 213, 204, 0.7);
  z-index: 100;
}

.bottom-buttons {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #6f5a45;
  color: #ffffff;
}

.btn-secondary {
  background: rgba(111, 90, 69, 0.08);
  color: #6f5a45;
}
