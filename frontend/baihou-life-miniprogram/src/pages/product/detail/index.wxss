/* ── 轮播图 ─────────────────────────────────────── */
.detail-swiper {
  overflow: hidden;
  border-radius: var(--bh-radius-card);
  box-shadow: var(--bh-shadow-card);
}

.detail-swiper,
.detail-swiper__image {
  width: 100%;
  height: 680rpx;
}

/* ── 摘要卡片 ─────────────────────────────────── */
.detail-summary {
  padding: 30rpx 28rpx 26rpx;
  margin-top: 18rpx;
}

.detail-summary__brand {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #9b938b;
  letter-spacing: 0.04em;
}

.detail-summary__brand::before {
  content: '';
  display: inline-block;
  width: 16rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #7d8a63, #c9a96e);
}

.detail-summary__name {
  margin-top: 14rpx;
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #2f2a26;
}

.detail-summary__desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6c655e;
}

/* 价格区 */
.detail-summary__price {
  margin-top: 26rpx;
  padding: 20rpx 22rpx;
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.05), rgba(125, 138, 99, 0.04));
  border-radius: 18rpx;
  border: 1rpx solid rgba(221, 213, 204, 0.50);
}

.detail-summary__price .bh-price__main {
  font-size: 44rpx;
}

.detail-summary__hint {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  background: rgba(238, 241, 232, 0.70);
  border-radius: 14rpx;
  font-size: 23rpx;
  color: #7d8a63;
  line-height: 1.5;
}

/* ── 规格卡片 ─────────────────────────────────── */
.detail-specs {
  padding: 26rpx 28rpx;
  margin-top: 18rpx;
}

.detail-specs__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2a26;
  letter-spacing: -0.01em;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid rgba(221, 213, 204, 0.60);
}

.detail-specs__row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.45);
}

.detail-specs__row:last-child {
  border-bottom: none;
}

.detail-specs__label {
  font-size: 25rpx;
  color: #9b938b;
  flex-shrink: 0;
}

.detail-specs__value {
  flex: 1;
  text-align: right;
  font-size: 25rpx;
  color: #2f2a26;
  font-weight: 500;
}

/* ── 操作区 ─────────────────────────────────────── */
.detail-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(221, 213, 204, 0.60);
  border-radius: var(--bh-radius-card);
  box-shadow: var(--bh-shadow-card);
}

.detail-actions .bh-button-primary {
  grid-column: span 2;
}

.detail-actions .bh-button-secondary {
  font-size: 26rpx;
}
