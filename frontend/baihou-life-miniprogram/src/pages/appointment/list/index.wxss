.appointment-create {
  position: relative;
  margin-bottom: 24rpx;
  padding: 30rpx 28rpx;
  background: linear-gradient(135deg, rgba(111, 90, 69, 0.12), rgba(125, 138, 99, 0.14));
  border-radius: 24rpx;
  overflow: hidden;
}

.appointment-create__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2a26;
}

.appointment-create__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7c746d;
  line-height: 1.5;
  padding-right: 40rpx;
}

.appointment-create__arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #6f5a45;
  border-bottom: 3rpx solid #6f5a45;
  transform: translateY(-50%) rotate(-45deg);
}

.appointment-list {
  display: grid;
  gap: 16rpx;
}

.appointment-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: var(--bh-shadow-soft);
  border-left: 8rpx solid #d4ccc4;
}

.appointment-card--pending {
  border-left-color: #c69238;
}

.appointment-card--confirmed {
  border-left-color: #7d8a63;
}

.appointment-card--in_progress {
  border-left-color: #6f5a45;
}

.appointment-card--completed {
  border-left-color: #5f8a74;
}

.appointment-card--cancelled {
  border-left-color: #c0b8b0;
}

.appointment-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.appointment-card__no {
  font-size: 26rpx;
  font-weight: 700;
  color: #2f2a26;
}

.appointment-card__meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #a09890;
}

.appointment-card__status {
  font-size: 24rpx;
  font-weight: 600;
  color: #6f5a45;
}

.appointment-card__service {
  margin-top: 18rpx;
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f0ebe4;
  font-size: 23rpx;
  color: #6c655e;
  font-weight: 500;
}

.appointment-card__hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9b938b;
}
