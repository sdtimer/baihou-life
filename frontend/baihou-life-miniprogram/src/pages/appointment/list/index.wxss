/* ── 新建预约按钮 ──────────────────────────────── */
.appointment-create {
  margin-bottom: 22rpx;
  width: 100%;
}

/* ── 预约列表 ─────────────────────────────────── */
.appointment-list {
  display: grid;
  gap: 16rpx;
}

.appointment-item {
  padding: 0;
  overflow: hidden;
}

/* 左侧状态色条 */
.appointment-item__bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
}

.appointment-item--pending .appointment-item__bar   { background: linear-gradient(180deg, #b9852b, #e8a83a); }
.appointment-item--confirmed .appointment-item__bar { background: linear-gradient(180deg, #4e6a7d, #6a8fa6); }
.appointment-item--in_progress .appointment-item__bar { background: linear-gradient(180deg, #6f5a45, #9a7a60); }
.appointment-item--completed .appointment-item__bar { background: linear-gradient(180deg, #3e7b57, #5ca574); }
.appointment-item--cancelled .appointment-item__bar { background: linear-gradient(180deg, #c0b8b0, #d4ccc4); }

.appointment-item__body {
  padding: 22rpx 24rpx;
  position: relative;
}

.appointment-item__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.appointment-item__no {
  font-size: 26rpx;
  font-weight: 700;
  color: #2f2a26;
}

.appointment-item__meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #a09890;
}

/* 服务类型 */
.appointment-item__service {
  margin-top: 16rpx;
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 244, 239, 0.90);
  border: 1rpx solid rgba(221, 213, 204, 0.55);
  font-size: 23rpx;
  color: #6c655e;
  font-weight: 500;
}
