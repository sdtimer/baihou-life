<bh-shell title="我的预约" subtitle="查看量尺、配送、安装等服务安排与状态进度。">
  <view class="appointment-create" bindtap="goCreate">
    <view class="appointment-create__title">新建预约</view>
    <view class="appointment-create__desc">提交新的服务需求，安排上门或履约时间</view>
    <view class="appointment-create__arrow"></view>
  </view>

  <bh-empty wx:if="{{loading}}" title="预约记录加载中" subtitle="正在同步你的服务安排。" />

  <view wx:elif="{{rows.length}}" class="appointment-list">
    <view
      wx:for="{{rows}}"
      wx:key="appointment_id"
      class="appointment-card appointment-card--{{item.status}}"
      data-id="{{item.appointment_id}}"
      bindtap="openDetail"
    >
      <view class="appointment-card__header">
        <view>
          <view class="appointment-card__no">{{item.appointment_no}}</view>
          <view class="appointment-card__meta">{{item.region_name}} · {{item.preferred_date}}</view>
        </view>
        <view class="appointment-card__status">{{item.status_text}}</view>
      </view>
      <view class="appointment-card__service">{{item.service_type_text}}</view>
      <view class="appointment-card__hint">点击查看详情</view>
    </view>
  </view>

  <bh-empty wx:else title="你还没有预约记录" subtitle="预约量尺、安装或配送后，会在这里看到状态更新。" />

</bh-shell>
