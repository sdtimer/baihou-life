/* ── 表单卡片 ────────────────────────────────────── */
.form-card {
  display: grid;
  gap: 0;
  padding: 0;
  overflow: hidden;
}

/* 表单行 */
.form-row {
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid rgba(221, 213, 204, 0.45);
  position: relative;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.03em;
  color: #b0a89e;
  margin-bottom: 10rpx;
}

/* 输入框 */
.form-card__input {
  width: 100%;
  height: 72rpx;
  padding: 0 4rpx;
  background: transparent;
  font-size: 28rpx;
  color: #2f2a26;
  border: none;
}

/* 服务类型选择 */
.form-card__group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 日期选择器 */
.form-picker {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #2f2a26;
}

.form-picker--placeholder {
  color: #c8c0b8;
}

.form-picker__arrow {
  font-size: 26rpx;
  color: #c8c0b8;
}

/* 文本域 */
.form-card__textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 0 4rpx;
  background: transparent;
  font-size: 27rpx;
  color: #2f2a26;
  line-height: 1.6;
  border: none;
}

/* 提交按钮行 */
.form-submit-row {
  padding: 24rpx 28rpx;
}

.form-submit-row .bh-button-primary {
  width: 100%;
}
