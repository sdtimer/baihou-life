<bh-shell title="预约服务时间" subtitle="日期不可早于今天，服务类型与区域要保持一致。">
  <view class="form-card bh-card">
    <view class="form-row">
      <view class="form-label">姓名</view>
      <input class="form-card__input" placeholder="你的称呼" data-field="customer_name" bindinput="bindField" value="{{form.customer_name}}" />
    </view>
    <view class="form-row">
      <view class="form-label">手机号</view>
      <input class="form-card__input" placeholder="11位手机号" type="number" maxlength="11" data-field="customer_phone" bindinput="bindField" value="{{form.customer_phone}}" />
    </view>
    <view class="form-row">
      <view class="form-label">服务类型</view>
      <view class="form-card__group">
        <view
          wx:for="{{serviceTypes}}"
          wx:key="value"
          class="bh-pill {{form.service_type === item.value ? 'bh-pill--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="pickService"
        >
          {{item.label}}
        </view>
      </view>
    </view>
    <view class="form-row">
      <view class="form-label">期望日期</view>
      <picker mode="date" start="{{minDate}}" bindchange="bindField" data-field="preferred_date">
        <view class="form-picker {{form.preferred_date ? '' : 'form-picker--placeholder'}}">
          <text>{{preferredDateText}}</text>
          <text class="form-picker__arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-row">
      <view class="form-label">备注地址</view>
      <textarea class="form-card__textarea" placeholder="补充地址或备注信息" data-field="remark" bindinput="bindField" value="{{form.remark}}" />
    </view>
    <view class="form-submit-row">
      <button class="bh-button-primary" loading="{{submitting}}" bindtap="submit">{{submitting ? '提交中' : '提交预约'}}</button>
    </view>
  </view>
</bh-shell>
